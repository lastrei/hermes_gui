# Frontend can normally use relative /api through Vite dev proxy.
# Set this only when the Next.js proxy is hosted elsewhere.
VITE_PROXY_BASE_URL=http://localhost:3000

# Next.js proxy -> Hermes API Server
HERMES_API_BASE_URL=http://localhost:8642
HERMES_API_KEY=replace-with-your-hermes-api-key
HERMES_MODEL=hermes-agent
PROXY_CORS_ORIGIN=http://localhost:5600
