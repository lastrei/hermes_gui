{
  "name": "hermes-gui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n proxy,web -c cyan,green \"npm:dev:proxy\" \"npm:dev:web\"",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:proxy": "npm --workspace apps/proxy run dev",
    "build": "npm --workspaces run build",
    "typecheck": "npm --workspaces run typecheck",
    "lint": "npm --workspaces run lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
