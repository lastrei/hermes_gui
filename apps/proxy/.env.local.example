# Hermes API Server from the provided curl:
# curl http://localhost:8642/v1/chat/completions \
#   -H "Authorization: Bearer SSand123$" \
#   -H "Content-Type: application/json" \
#   -d '{"model": "hermes-agent", "messages": [{"role": "user", "content": "Hello!"}]}'

HERMES_API_BASE_URL=http://localhost:8642
HERMES_API_KEY=replace-with-your-hermes-api-key
HERMES_MODEL=hermes-agent

# Used only when the browser calls the Next proxy directly instead of through Vite's /api dev proxy.
PROXY_CORS_ORIGIN=http://localhost:5600
